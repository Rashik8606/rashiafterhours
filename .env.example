# Google Sheets (recommended for contact form + message admin on Vercel)
GOOGLE_CREDENTIALS={"type":"service_account",...}
# Or path to service account JSON file (local dev only)
# GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json

GOOGLE_SHEET_NAME=Portfolio Messages
# Optional: spreadsheet ID (faster than name lookup)
# GOOGLE_SHEET_ID=
